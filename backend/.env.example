# Backend Environment Variables for RMS
# Copy to .env and fill values

DB_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/rmsdb?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production-must-be-32-chars-min
JWT_EXPIRES_IN=7d
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FRONTEND_URL=http://localhost:5173,https://your-frontend.vercel.app

# Render.com will use these
